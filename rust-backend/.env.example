# Database
DATABASE_URL=postgres://library_user:library_pass@localhost:5432/library_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=library-jwt-secret-key-2024-change-in-production
JWT_EXPIRY_MS=86400000

# Server
PORT=8080

# File uploads
UPLOAD_DIR=/app/uploads

# Twilio (leave blank for dev mode — OTP will be 123456)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SendGrid (leave blank for dev mode)
SENDGRID_API_KEY=

# Meta WhatsApp
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# Payment gateway: CASHFREE or RAZORPAY
PAYMENT_GATEWAY=CASHFREE

# Razorpay (leave blank for dev mode — mock orders generated)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cashfree (leave blank for dev mode — mock orders generated)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox

# Admin notifications
ADMIN_EMAIL=admin@targetzone.co.in
ADMIN_WHATSAPP=
ADMIN_PHONES=

# SMTP (for email, if not using SendGrid)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
